<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home" inherit_id="portal.portal_my_home" priority="100">
        <!-- Add our dashboard before the default portal docs -->
        <xpath expr="//div[hasclass('o_portal_my_home')]" position="before">
            <div class="o_employee_portal_dashboard mt-4 mb-5">
                <div class="container">
                    <div class="row g-4">
                        <!-- Profile Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/profile" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-user-circle-o fa-3x text-primary"></i>
                                    </div>
                                    <h5 class="card-title text-dark">My Profile</h5>
                                    <p class="card-text text-muted small">Personal Details</p>
                                </div>
                            </a>
                        </div>

                        <!-- Attendance Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/attendance" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-clock-o fa-3x text-success"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Attendance</h5>
                                    <p class="card-text text-muted small">
                                        <t t-if="dashboard_stats.get('attendance_status') == 'checked_in'">Currently In</t>
                                        <t t-else="">Currently Out</t>
                                    </p>
                                </div>
                            </a>
                        </div>

                        <!-- Time Off Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/leaves" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-plane fa-3x text-warning"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Time Off</h5>
                                    <p class="card-text text-muted small">Requests &amp; Balance</p>
                                </div>
                            </a>
                        </div>

                        <!-- Payroll Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/payroll" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-money fa-3x text-info"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Payroll</h5>
                                    <p class="card-text text-muted small">Payslips &amp; History</p>
                                </div>
                            </a>
                        </div>

                        <!-- Tasks Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/tasks" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-tasks fa-3x text-danger"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Tasks</h5>
                                    <p class="card-text text-muted small">Assigned Work</p>
                                </div>
                            </a>
                        </div>

                        <!-- Timesheets Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/timesheets" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-calendar-check-o fa-3x text-secondary"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Timesheets</h5>
                                    <p class="card-text text-muted small">Log Hours</p>
                                </div>
                            </a>
                        </div>

                        <!-- Expenses Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/expenses" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-file-text-o fa-3x text-dark"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Expenses</h5>
                                    <p class="card-text text-muted small">Submit Receipts</p>
                                </div>
                            </a>
                        </div>

                        <!-- Weekly Schedule Tile -->
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/my/schedule" class="o_portal_card shadow-sm border-0 text-decoration-none">
                                <div class="card-body text-center p-4">
                                    <div class="icon-wrapper mb-3">
                                        <i class="fa fa-calendar fa-3x text-primary"></i>
                                    </div>
                                    <h5 class="card-title text-dark">Schedule</h5>
                                    <p class="card-text text-muted small">Shift Planning</p>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Attendance Page Template -->
    <template id="portal_my_attendance" name="My Attendance">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-5 o_portal_attendance_page">
                <div class="row justify-content-center">
                    <div class="col-lg-10">
                        <!-- Check-in/out Action Card -->
                        <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                            <div class="card-body p-5 text-center bg-white">
                                <div class="mb-4">
                                    <div class="attendance-icon-large mb-3">
                                        <i t-attf-class="fa fa-clock-o fa-5x #{'text-success' if employee.attendance_state != 'checked_in' else 'text-danger'} animate-pulse"></i>
                                    </div>
                                    <h2 class="fw-bold">
                                        <t t-if="employee.attendance_state == 'checked_in'">You are Checked In</t>
                                        <t t-else="">You are Checked Out</t>
                                    </h2>
                                    <p class="text-muted">Recording your work hours with GPS location</p>
                                </div>

                                <div class="d-flex justify-content-center">
                                    <button id="o_portal_attendance_toggle_btn" 
                                            t-attf-class="btn btn-lg px-5 py-3 shadow-sm fw-bold #{'btn-danger' if employee.attendance_state == 'checked_in' else 'btn-success'}"
                                            style="border-radius: 50px; min-width: 250px; font-size: 1.5rem;">
                                        <i t-attf-class="fa #{'fa-sign-out' if employee.attendance_state == 'checked_in' else 'fa-sign-in'} me-2"></i>
                                        <t t-if="employee.attendance_state == 'checked_in'">Check Out Now</t>
                                        <t t-else="">Check In Now</t>
                                    </button>
                                </div>
                                <div id="o_portal_attendance_status" class="mt-3 text-muted small">
                                    <t t-if="employee.last_attendance_id and not employee.last_attendance_id.check_out">
                                        Started at: <span t-field="employee.last_attendance_id.check_in" t-options='{"widget": "datetime", "format": "hh:mm a"}'/>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Attendance History Table -->
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                                <h4 class="mb-0 fw-bold">Recent Attendance History</h4>
                                <span class="badge bg-primary rounded-pill">Last 10 Records</span>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="ps-4">Date</th>
                                                <th>Check In</th>
                                                <th>Check Out</th>
                                                <th class="text-center">Work Hours</th>
                                                <th class="pe-4 text-end">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody id="attendance_history_body">
                                            <t t-foreach="attendances" t-as="att">
                                                <tr>
                                                    <td class="ps-4 fw-bold text-dark">
                                                        <span t-field="att.check_in" t-options='{"widget": "date"}'/>
                                                    </td>
                                                    <td>
                                                        <span class="text-success"><i class="fa fa-sign-in me-1"></i> <span t-field="att.check_in" t-options='{"widget": "datetime", "format": "hh:mm a"}'/></span>
                                                    </td>
                                                    <td>
                                                        <t t-if="att.check_out">
                                                            <span class="text-danger"><i class="fa fa-sign-out me-1"></i> <span t-field="att.check_out" t-options='{"widget": "datetime", "format": "hh:mm a"}'/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-success animate-pulse">Working...</span>
                                                        </t>
                                                    </td>
                                                    <td class="text-center">
                                                        <t t-if="att.worked_hours">
                                                            <span class="fw-bold" t-esc="'%02d:%02d' % (int(att.worked_hours), int((att.worked_hours - int(att.worked_hours)) * 60))"/> hrs
                                                        </t>
                                                        <t t-else="">-</t>
                                                    </td>
                                                    <td class="pe-4 text-end">
                                                        <t t-if="att.in_latitude">
                                                            <i class="fa fa-map-marker text-primary" title="GPS Captured"></i>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Time Off Page Template -->
    <template id="portal_my_leaves" name="My Time Off">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-12">
                        <!-- Alert for success/error -->
                        <div t-if="success" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                            <i class="fa fa-check-circle me-2"></i> Leave request submitted successfully!
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                        <div t-if="error" class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                            <i class="fa fa-exclamation-circle me-2"></i> <t t-esc="error"/>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold mb-0">Time Off &amp; Leaves</h2>
                            <button type="button" class="btn btn-primary px-4 py-2 shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#newLeaveModal">
                                <i class="fa fa-plus me-2"></i> Request Time Off
                            </button>
                        </div>

                        <!-- Leave Balances -->
                        <div class="row g-3 mb-4">
                            <t t-foreach="balances" t-as="balance">
                                <div class="col-6 col-md-4 col-lg-3">
                                    <div class="card shadow-sm border-0 h-100 text-center p-3" style="border-radius: 15px;">
                                        <div class="text-muted small mb-1" t-esc="balance.get('name')"/>
                                        <div class="h3 fw-bold mb-0 text-primary" t-esc="balance.get('remaining_leaves')"/>
                                        <div class="text-muted x-small">Days Remaining</div>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <!-- Leave History Table -->
                        <div class="card shadow-sm border-0 overflow-hidden">
                            <div class="card-header bg-white border-0 py-3">
                                <h4 class="mb-0 fw-bold">My Leave Requests</h4>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="ps-4">Leave Type</th>
                                                <th>Start Date</th>
                                                <th>End Date</th>
                                                <th>Duration</th>
                                                <th>Status</th>
                                                <th class="pe-4 text-end">Reason</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="leaves" t-as="leave">
                                                <tr>
                                                    <td class="ps-4">
                                                        <span class="fw-bold text-dark" t-field="leave.holiday_status_id.name"/>
                                                    </td>
                                                    <td><span t-field="leave.request_date_from" t-options='{"widget": "date"}'/></td>
                                                    <td><span t-field="leave.request_date_to" t-options='{"widget": "date"}'/></td>
                                                    <td><span t-field="leave.number_of_days"/> Days</td>
                                                    <td>
                                                        <span t-attf-class="badge rounded-pill px-3 py-2 #{'bg-success' if leave.state == 'validate' else 'bg-warning' if leave.state == 'confirm' else 'bg-danger' if leave.state == 'refuse' else 'bg-secondary'}" t-field="leave.state"/>
                                                    </td>
                                                    <td class="pe-4 text-end text-muted small">
                                                        <span t-field="leave.name"/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="not leaves">
                                                <tr>
                                                    <td colspan="6" class="text-center py-5 text-muted">
                                                        <i class="fa fa-calendar-times-o fa-3x mb-3 d-block opacity-25"></i>
                                                        No leave requests found.
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- New Leave Request Modal -->
            <div class="modal fade" id="newLeaveModal" tabindex="-1" aria-labelledby="newLeaveModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                        <form action="/my/leaves/apply" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="modal-header border-0 pb-0">
                                <h4 class="modal-title fw-bold" id="newLeaveModalLabel">New Leave Request</h4>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="mb-3">
                                    <label class="form-label text-muted small">Leave Type</label>
                                    <select name="holiday_status_id" class="form-select" required="required">
                                        <t t-foreach="leave_types" t-as="type">
                                            <option t-att-value="type.id" t-esc="type.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small">Start Date</label>
                                        <input type="date" name="date_from" class="form-control" required="required"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small">End Date</label>
                                        <input type="date" name="date_to" class="form-control" required="required"/>
                                    </div>
                                </div>
                                <div class="mb-0">
                                    <label class="form-label text-muted small">Reason</label>
                                    <textarea name="name" class="form-control" rows="3" placeholder="Explain why you need this time off..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer border-0 pt-0">
                                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">Submit Request</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Payroll Page Template -->
    <template id="portal_my_payroll" name="My Payroll">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-12">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold mb-0">Payroll &amp; Payslips</h2>
                        </div>

                        <!-- Payslip History Table -->
                        <div class="card shadow-sm border-0 overflow-hidden">
                            <div class="card-header bg-white border-0 py-3">
                                <h4 class="mb-0 fw-bold">My Payslips</h4>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="ps-4">Reference</th>
                                                <th>Period</th>
                                                <th>Basic Salary</th>
                                                <th>Net Salary</th>
                                                <th>Status</th>
                                                <th class="pe-4 text-end">Download</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="payslips" t-as="slip">
                                                <tr>
                                                    <td class="ps-4">
                                                        <span class="fw-bold text-dark" t-field="slip.number"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="slip.date_from" t-options='{"widget": "date", "format": "MMM YYYY"}'/>
                                                    </td>
                                                    <td><span t-field="slip.basic_wage" t-options='{"widget": "monetary", "display_currency": slip.company_id.currency_id}'/></td>
                                                    <td><span class="fw-bold text-primary" t-field="slip.net_wage" t-options='{"widget": "monetary", "display_currency": slip.company_id.currency_id}'/></td>
                                                    <td>
                                                        <span t-attf-class="badge rounded-pill px-3 py-2 #{'bg-success' if slip.state in ['done', 'paid'] else 'bg-warning'}" t-field="slip.state"/>
                                                    </td>
                                                    <td class="pe-4 text-end">
                                                        <a t-attf-href="/report/pdf/hr_payroll.action_report_payslip/#{slip.id}" target="_blank" class="btn btn-sm btn-outline-primary rounded-circle" title="Download PDF">
                                                            <i class="fa fa-download"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="not payslips">
                                                <tr>
                                                    <td colspan="6" class="text-center py-5 text-muted">
                                                        <i class="fa fa-file-pdf-o fa-3x mb-3 d-block opacity-25"></i>
                                                        No payslips found.
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
